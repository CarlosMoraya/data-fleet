{
  "name": "beta-fleet",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:audit": "npm audit --audit-level=high",
    "test:smoke": "playwright test e2e/smoke/app-smoke.spec.ts --project=chromium",
    "test:e2e": "playwright test",
    "test:e2e:auth": "playwright test e2e/completed/auth-storage-state.spec.ts --project=chromium",
    "test:e2e:pending": "PLAYWRIGHT_INCLUDE_PENDING=1 playwright test e2e/pending",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:shippers": "playwright test e2e/shippers-operational-units.spec.ts",
    "migrate:shippers": "node scripts/exec-migration.mjs",
    "seed:demo:betafleet": "node scripts/seed-betafleet-demo.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/query-sync-storage-persister": "^5.101.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-persist-client": "^5.101.0",
    "@vitejs/plugin-react": "^6.0.2",
    "better-sqlite3": "^12.4.1",
    "clsx": "^2.1.1",
    "csv-parse": "^6.2.1",
    "dexie": "^4.3.0",
    "dotenv": "^17.4.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.4.21",
    "express": "^4.21.2",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.22.4",
    "typescript": "~5.8.2",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
  }
}
